#!/bin/bash
# ダブルクリック起動用ランチャー。実体はリポジトリ直下の run.sh
# (python の選定ロジックを二重管理しないため、ここでは選ばず run.sh に委ねる)。
# バンドルはリポジトリ内に置いたまま使う前提(自分の位置から 3 つ上 = リポジトリ root)。
#
# 既知の制限: Dock 上の表示は「Python」になる。Tk が python framework の bundle 情報で
# 自己申告するためで、exec 連鎖でもバンドル内 symlink 経由でも上書きされる(実測済み)。
# 直すには pyobjc かコンパイル済みスタブが要るので、方針(標準ライブラリのみ)を優先して
# 受け入れる。ウィンドウタイトルは Ubuntu Remote で、機能面の影響はない。
REPO="$(cd "$(dirname "$0")/../../.." && pwd)"
exec /bin/bash "$REPO/run.sh"
